#!/bin/bash
# Launcher for the Super Puppy menu bar app.
# Uses the .app bundle so macOS attributes permissions (screen recording, etc.)
# to "Super Puppy" and shows the correct name in alt-tab.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" || echo "$0")")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
exec open -W "$REPO_DIR/app/SuperPuppy.app"
