#!/bin/bash
# Launcher for the Super Puppy menu bar app.
# Runs the .app binary directly so launchd owns the process and captures
# stdout/stderr.  macOS reads CFBundleName from the surrounding bundle
# for Cmd-Tab and permission attribution.
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" || echo "$0")")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
CONFIG_DIR="$HOME/.config/local-models"

# ── User quit check ───────────────────────────────────────────────
# The C launcher always exits non-zero so launchd restarts us.
# quit_app writes stay_down to request a permanent stop.  We check
# it HERE (at startup, before anything runs) so the exit 0 is
# guaranteed to reach launchd.
STAY_DOWN="$CONFIG_DIR/stay_down"
if [ -f "$STAY_DOWN" ]; then
    rm -f "$STAY_DOWN"
    exit 0
fi

# ── Pre-Python rollback check ──────────────────────────────────────
# Catches import-level crashes that kill Python before the in-app
# rollback code can run.  Uses a two-phase marker:
#
#   update_started  — written by _auto_update() before os._exit(1)
#   launch_attempted — written HERE on the first launch after update
#
# First launch after update:  update_started exists, launch_attempted
#   does NOT → create launch_attempted, proceed normally.
# Second launch (new code crashed): BOTH exist → roll back.
# App survives 90s: Python clears both markers.
UPDATE_STARTED="$CONFIG_DIR/update_started"
UPDATE_PRE_HASH="$CONFIG_DIR/update_pre_hash"
UPDATE_SKIPPED="$CONFIG_DIR/update_skipped"
LAUNCH_ATTEMPTED="$CONFIG_DIR/launch_attempted"
CRASH_WINDOW=90

if [ -f "$UPDATE_STARTED" ]; then
    started=$(cat "$UPDATE_STARTED" 2>/dev/null)
    now=$(date +%s)
    started_int=${started%%.*}
    elapsed=$((now - started_int))

    if [ "$elapsed" -lt "$CRASH_WINDOW" ]; then
        if [ -f "$LAUNCH_ATTEMPTED" ]; then
            # Second launch within crash window — new code crashed, roll back
            pre_hash=$(cat "$UPDATE_PRE_HASH" 2>/dev/null)
            if [ -n "$pre_hash" ]; then
                bad_hash=$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null)
                echo "[pre-python-rollback] Crash within ${elapsed}s of update — rolling back to ${pre_hash:0:8}" >&2
                git -C "$REPO_DIR" checkout --force "$pre_hash" 2>/dev/null

                if [ -x "$REPO_DIR/bin/post-update.sh" ]; then
                    "$REPO_DIR/bin/post-update.sh" 2>&1 | sed 's/^/[rollback] /' >&2 || true
                fi

                if [ -n "$bad_hash" ]; then
                    mkdir -p "$CONFIG_DIR"
                    printf '%s\n%s' "$bad_hash" "$(date +%s)" > "$UPDATE_SKIPPED"
                fi

                rm -f "$UPDATE_STARTED" "$UPDATE_PRE_HASH" "$LAUNCH_ATTEMPTED"
            fi
        else
            # First launch after update — mark that we tried, proceed
            touch "$LAUNCH_ATTEMPTED"
        fi
    else
        # Outside crash window — clean up stale markers
        rm -f "$LAUNCH_ATTEMPTED"
    fi
fi

exec "$REPO_DIR/app/SuperPuppy.app/Contents/MacOS/super-puppy"
