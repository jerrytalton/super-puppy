#!/bin/bash
#
# Wrapper that detects whether the desktop model server is reachable,
# sets OLLAMA_API_URL and OPENAI_API_BASE accordingly, then launches
# the PAL MCP server. Called from Claude Code's MCP settings.
#
# If the desktop is reachable  → point to it (use its big models)
# If not                       → point to localhost (use local fallback)

set -euo pipefail

CONF="$HOME/.config/local-models/network.conf"

# Defaults (localhost fallback)
OLLAMA_API_URL="http://localhost:11434"
OPENAI_API_BASE="http://localhost:8000"

if [ -f "$CONF" ]; then
    # shellcheck source=/dev/null
    source "$CONF"

    # Probe the desktop — quick TCP check on both ports
    if curl -sf --connect-timeout "$PROBE_TIMEOUT" \
         "http://${MODEL_SERVER_HOST}:${OLLAMA_PORT}/api/version" > /dev/null 2>&1; then

        OLLAMA_API_URL="http://${MODEL_SERVER_HOST}:${OLLAMA_PORT}"

        # MLX server might not be running on the desktop; only use if reachable
        if curl -sf --connect-timeout "$PROBE_TIMEOUT" \
             "http://${MODEL_SERVER_HOST}:${MLX_PORT}/v1/models" > /dev/null 2>&1; then
            OPENAI_API_BASE="http://${MODEL_SERVER_HOST}:${MLX_PORT}"
        fi

        echo "PAL MCP: using desktop at ${MODEL_SERVER_HOST}" >&2
    else
        echo "PAL MCP: desktop not reachable, using localhost" >&2
    fi
fi

export OLLAMA_API_URL
export OPENAI_API_BASE
export OPENAI_API_KEY="${OPENAI_API_KEY:-local}"
export DEFAULT_MODEL="${DEFAULT_MODEL:-auto}"
export DISABLED_TOOLS="${DISABLED_TOOLS:-analyze,refactor,testgen,secaudit,docgen,tracer}"

exec uvx --from "git+https://github.com/BeehiveInnovations/pal-mcp-server.git" pal-mcp-server
