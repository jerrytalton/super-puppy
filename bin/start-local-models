#!/bin/bash
#
# Starts the local model infrastructure: Ollama + MLX-OpenAI-Server.
# Auto-detects system RAM and picks the appropriate MLX config.
# On client machines, checks if the model server is reachable first —
# if so, skips starting local servers (Claude will use the server via MCP).
#
# Usage:
#   start-local-models            Start all services (or detect server)
#   start-local-models --local    Force local servers even if server is reachable
#   start-local-models --stop     Stop all services
#   start-local-models --status   Show what's running

set -euo pipefail

# Ensure Homebrew is on PATH — launchd and app bundles get a minimal PATH
# that doesn't include /opt/homebrew/bin, which breaks tools like ffmpeg
# that MLX Whisper needs at runtime.
if [ -d /opt/homebrew/bin ] && [[ ":$PATH:" != *":/opt/homebrew/bin:"* ]]; then
    export PATH="/opt/homebrew/bin:$PATH"
fi

MLX_CONFIG_DIR="$HOME/.config/mlx-server"
NETWORK_CONF="$HOME/.config/local-models/network.conf"
OLLAMA_PID_FILE="/tmp/ollama-serve.pid"

# Load network config
MODEL_SERVER_HOST=""
OLLAMA_PORT=11434
MLX_PORT=8000
PROBE_TIMEOUT=2

if [ -f "$NETWORK_CONF" ]; then
    # shellcheck source=/dev/null
    source "$NETWORK_CONF"
fi

get_ram_gb() {
    sysctl -n hw.memsize | awk '{printf "%d", $1 / 1073741824}'
}

is_server() {
    [ "${IS_SERVER:-false}" = "true" ]
}

server_is_reachable() {
    [ -n "$MODEL_SERVER_HOST" ] && \
    curl -sf --connect-timeout "$PROBE_TIMEOUT" \
        "http://${MODEL_SERVER_HOST}:${OLLAMA_PORT}/api/version" > /dev/null 2>&1
}

pick_mlx_config() {
    local ram_gb
    ram_gb=$(get_ram_gb)

    if [ "$ram_gb" -ge 256 ]; then
        echo "$MLX_CONFIG_DIR/config.yaml"
        echo "  Detected ${ram_gb}GB RAM — using high-memory config (all models)." >&2
    elif [ "$ram_gb" -ge 48 ]; then
        echo "$MLX_CONFIG_DIR/config-laptop.yaml"
        echo "  Detected ${ram_gb}GB RAM — using laptop config (lighter models)." >&2
    else
        echo ""
        echo "  Detected ${ram_gb}GB RAM — too little for MLX server, skipping." >&2
    fi
}

wait_for_service() {
    local url="$1" name="$2" max_wait="${3:-30}"
    local elapsed=0
    while [ "$elapsed" -lt "$max_wait" ]; do
        if curl -sf "$url" > /dev/null 2>&1; then
            echo "  $name is up after ${elapsed}s."
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    echo "  WARNING: $name did not respond within ${max_wait}s."
    return 1
}

stop_services() {
    echo "Stopping Super Puppy services..."

    pkill -f "mlx-openai-server" 2>/dev/null && echo "  MLX-OpenAI-Server stopped." || echo "  MLX-OpenAI-Server not running."

    echo "  Ollama left running (system service, not Super Puppy's to stop)."
    rm -f "$OLLAMA_PID_FILE"

    echo "Done."
    exit 0
}

show_status() {
    local ram_gb
    ram_gb=$(get_ram_gb)

    echo "Machine: ${ram_gb}GB RAM ($(is_server && echo 'server' || echo 'client'))"
    echo ""

    # Check server reachability (for clients)
    if ! is_server && [ -n "$MODEL_SERVER_HOST" ]; then
        if server_is_reachable; then
            echo "Server ($MODEL_SERVER_HOST): reachable"
            echo "  Ollama:       http://${MODEL_SERVER_HOST}:${OLLAMA_PORT}"
            echo "  MLX-OpenAI:   http://${MODEL_SERVER_HOST}:${MLX_PORT}"
            echo ""
        else
            echo "Server ($MODEL_SERVER_HOST): not reachable"
            echo ""
        fi
    fi

    echo "Local services:"
    if pgrep -x ollama > /dev/null; then
        echo "  Ollama:            running (http://localhost:11434)"
        ollama list 2>/dev/null | sed 's/^/    /' || true
    else
        echo "  Ollama:            not running"
    fi

    if curl -sf http://localhost:8000/v1/models > /dev/null 2>&1; then
        echo "  MLX-OpenAI-Server: running (http://localhost:8000)"
        curl -sf http://localhost:8000/v1/models \
            | python3 -c "import sys,json; [print(f'    {m[\"id\"]}') for m in json.load(sys.stdin).get('data',[])]" \
            || true
    else
        echo "  MLX-OpenAI-Server: not running"
    fi
    exit 0
}

FORCE_LOCAL=false

case "${1:-}" in
    --stop)   stop_services ;;
    --status) show_status ;;
    --local)  FORCE_LOCAL=true ;;
esac

echo "Starting local model infrastructure..."
echo ""

# --- Server detection (clients only) ---
if ! is_server && [ "$FORCE_LOCAL" = false ] && server_is_reachable; then
    echo "Model server detected at $MODEL_SERVER_HOST"
    echo "  Ollama:     http://${MODEL_SERVER_HOST}:${OLLAMA_PORT}"
    echo "  MLX-OpenAI: http://${MODEL_SERVER_HOST}:${MLX_PORT}"
    echo ""
    echo "Skipping local server startup — Claude will use the server via MCP."
    echo "Use 'start-local-models --local' to force local servers anyway."
    exit 0
fi

# --- Ollama ---
if is_server; then
    # Server: bind to all interfaces so clients on the LAN can reach us
    export OLLAMA_HOST="0.0.0.0:11434"
    # Keep core models loaded to avoid swap delays on MCP tool calls
    export OLLAMA_MAX_LOADED_MODELS=6
fi

if pgrep -x ollama > /dev/null; then
    if is_server && ! curl -sf "http://0.0.0.0:${OLLAMA_PORT}/api/version" > /dev/null 2>&1; then
        echo "Ollama running but not bound to 0.0.0.0 — restarting for LAN access..."
        # Kill Ollama.app first — it auto-respawns ollama serve with localhost binding
        pkill -f Ollama.app 2>/dev/null || true
        pkill -x ollama
        sleep 1
        ollama serve > /dev/null 2>&1 &
        echo $! > "$OLLAMA_PID_FILE"
        wait_for_service "http://localhost:${OLLAMA_PORT}/api/version" "Ollama" 10 || true
    else
        echo "Ollama already running."
    fi
else
    echo "Starting Ollama..."
    ollama serve > /dev/null 2>&1 &
    echo $! > "$OLLAMA_PID_FILE"
    if ! wait_for_service "http://localhost:${OLLAMA_PORT}/api/version" "Ollama" 10; then
        echo "  ERROR: Ollama failed to start." >&2
    fi
fi

# --- MLX-OpenAI-Server ---
mlx_config=$(pick_mlx_config)

if [ -z "$mlx_config" ]; then
    echo "  Skipping MLX-OpenAI-Server."
elif [ ! -f "$mlx_config" ]; then
    echo "Error: MLX config not found at $mlx_config"
    echo "Run install.sh to symlink config files."
    exit 1
elif curl -sf "http://localhost:${MLX_PORT}/v1/models" > /dev/null 2>&1; then
    echo "MLX-OpenAI-Server already running."
else
    echo "Starting MLX-OpenAI-Server with $(basename "$mlx_config")..."
    MLX_LOG="/tmp/local-models-mlx-startup.log"
    cd "$HOME"
    mlx-openai-server launch --config "$mlx_config" --no-log-file > "$MLX_LOG" 2>&1 &
    disown
    if ! wait_for_service "http://localhost:${MLX_PORT}/v1/models" "MLX-OpenAI-Server" 60; then
        echo "  ERROR: MLX-OpenAI-Server failed to start. Check config: $mlx_config" >&2
        echo "  Log: $MLX_LOG" >&2
    fi
fi

# --- Summary ---
echo ""
if is_server; then
    echo "Model server running (LAN-accessible):"
    echo "  Ollama:       http://0.0.0.0:${OLLAMA_PORT}"
    echo "  MLX-OpenAI:   http://0.0.0.0:${MLX_PORT}"
    echo ""
    echo "Other machines on the LAN can reach this at:"
    echo "  http://$(scutil --get LocalHostName 2>/dev/null || hostname -s).local:${OLLAMA_PORT}"
    echo "  http://$(scutil --get LocalHostName 2>/dev/null || hostname -s).local:${MLX_PORT}"
else
    echo "Local models ready (fallback mode):"
    echo "  Ollama:       http://localhost:${OLLAMA_PORT}"
    echo "  MLX-OpenAI:   http://localhost:${MLX_PORT}"
fi
echo ""
echo "Commands:"
echo "  start-local-models --status   Show running models"
echo "  start-local-models --stop     Stop all services"
