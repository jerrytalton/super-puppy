#!/bin/bash
#
# Launch Claude Code fully local — all requests go to Ollama.
# Reads the preferred model from menu bar preferences, or falls back to defaults.

set -euo pipefail

PREFS="$HOME/.config/local-models/mcp_preferences.json"
CONF="$HOME/.config/local-models/network.conf"

# Determine Ollama URL (desktop on LAN or localhost)
OLLAMA_URL="http://localhost:11434"
if [ -f "$CONF" ]; then
    source "$CONF"
    if [ -n "${MODEL_SERVER_HOST:-}" ]; then
        HOST_IP=$(python3 -c "import socket; print(socket.gethostbyname('${MODEL_SERVER_HOST}'))" 2>/dev/null || echo "")
        if [ -n "$HOST_IP" ] && curl -sf --connect-timeout "${PROBE_TIMEOUT:-2}" \
             "http://${HOST_IP}:${OLLAMA_PORT:-11434}/api/version" > /dev/null 2>&1; then
            OLLAMA_URL="http://${HOST_IP}:${OLLAMA_PORT:-11434}"
        fi
    fi
fi

# Read preferred model from menu bar preferences
MODEL=""
if [ -f "$PREFS" ]; then
    MODEL=$(python3 -c "import json; print(json.load(open('$PREFS')).get('general',''))" 2>/dev/null || echo "")
fi

# Fallback: pick first available model from Ollama
# Prefer base names without tags — Claude Code may strip the tag.
if [ -z "$MODEL" ]; then
    MODEL=$(curl -sf "$OLLAMA_URL/v1/models" 2>/dev/null \
        | python3 -c "
import sys, json
models = [m['id'] for m in json.loads(sys.stdin.read()).get('data', [])]
skip = ('flux', 'image', 'whisper', 'ocr', 'nsfw')
# Prefer :latest variants (Claude Code sends bare names)
for m in models:
    if 'qwen3.5' in m and m.endswith(':latest'):
        print(m.split(':')[0]); exit()
for m in models:
    if m.endswith(':latest') and not any(s in m for s in skip):
        print(m.split(':')[0]); exit()
# Any model
for m in models:
    if not any(s in m for s in skip):
        print(m); exit()
" 2>/dev/null || echo "")
fi

if [ -z "$MODEL" ]; then
    echo "No models available at $OLLAMA_URL" >&2
    exit 1
fi

echo "Local mode: $MODEL at $OLLAMA_URL" >&2

exec env \
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="$OLLAMA_URL" \
    ANTHROPIC_API_KEY="" \
    claude --model "$MODEL" "$@"
