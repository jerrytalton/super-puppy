#!/bin/bash
#
# Wrapper that detects the desktop model server via Tailscale,
# sets OLLAMA_URL and MLX_URL, then launches the local-models MCP server.

set -euo pipefail

CONF="$HOME/.config/local-models/network.conf"
REPO_DIR="$(cd "$(dirname "$(readlink "$0" || echo "$0")")/.." && pwd)"

OLLAMA_URL="http://localhost:11434"
MLX_URL="http://localhost:8000"

# User can force local mode via env var or mode.conf (written by the menu bar app)
MODE_CONF="$HOME/.config/local-models/mode.conf"
FORCE_LOCAL="${FORCE_LOCAL:-false}"
if [ "$FORCE_LOCAL" != "true" ] && [ -f "$MODE_CONF" ]; then
    # shellcheck source=/dev/null
    source "$MODE_CONF"
fi

if [ "$FORCE_LOCAL" = "true" ]; then
    echo "local-models MCP: forced local mode, skipping desktop probe" >&2
elif [ -f "$CONF" ]; then
    # shellcheck source=/dev/null
    source "$CONF"

    DESKTOP_FOUND=false

    # Resolve desktop peer via Tailscale.  We need the FQDN, not just the IP:
    # the desktop binds Ollama and MLX to 127.0.0.1, and `tailscale serve`
    # exposes them only via https://${FQDN}:${PORT}. A plain http probe to
    # the IP would always fail.
    if [ -n "${TAILSCALE_HOSTNAME:-}" ] && command -v tailscale > /dev/null 2>&1; then
        DESKTOP_FQDN=$(tailscale status --json 2>/dev/null | python3 -c "
import json, sys
d = json.load(sys.stdin)
if d.get('BackendState') != 'Running':
    sys.exit(0)
for peer in d.get('Peer', {}).values():
    if peer.get('HostName', '') == '${TAILSCALE_HOSTNAME}':
        print(peer.get('DNSName', '').rstrip('.'))
        break
" 2>/dev/null || true)

        if [ -n "$DESKTOP_FQDN" ]; then
            if curl -sf --connect-timeout "${PROBE_TIMEOUT:-2}" \
                 "https://${DESKTOP_FQDN}:${OLLAMA_PORT:-11434}/api/version" > /dev/null 2>&1; then
                OLLAMA_URL="https://${DESKTOP_FQDN}:${OLLAMA_PORT:-11434}"
                echo "local-models MCP: using desktop Ollama via Tailscale (${DESKTOP_FQDN})" >&2
                DESKTOP_FOUND=true
            fi

            if curl -sf --connect-timeout "${PROBE_TIMEOUT:-2}" \
                 "https://${DESKTOP_FQDN}:${MLX_PORT:-8000}/v1/models" > /dev/null 2>&1; then
                MLX_URL="https://${DESKTOP_FQDN}:${MLX_PORT:-8000}"
                echo "local-models MCP: using desktop MLX via Tailscale (${DESKTOP_FQDN})" >&2
                DESKTOP_FOUND=true
            fi
        fi
    fi

    if [ "$DESKTOP_FOUND" = "false" ]; then
        echo "local-models MCP: desktop unreachable via Tailscale, using localhost" >&2
    fi
fi

export OLLAMA_URL
export MLX_URL

# Auth token: use cached file, only hit 1Password if no cache exists
TOKEN_CACHE="$HOME/.config/local-models/mcp_auth_token"

if [ -f "$TOKEN_CACHE" ] && [ -s "$TOKEN_CACHE" ]; then
    MCP_AUTH_TOKEN=$(cat "$TOKEN_CACHE")
else
    if [ -n "${OP_REF:-}" ]; then
        MCP_AUTH_TOKEN=$(op read "$OP_REF" 2>/dev/null || true)
    fi
    if [ -n "$MCP_AUTH_TOKEN" ]; then
        (umask 077 && echo "$MCP_AUTH_TOKEN" > "$TOKEN_CACHE")
    else
        echo "local-models MCP: WARNING: no auth token available" >&2
    fi
fi
export MCP_AUTH_TOKEN

exec uv run --python 3.12 "$REPO_DIR/mcp/local-models-server.py"
